{
  "version": "1.0.0",
  "description": "Canonical test vectors for patent utility prosecution (Appendix B). Generated from Rust SDK reference implementation.",
  "generated": "2026-02-19T00:00:00Z",
  "patent_claims": "These vectors provide reduction-to-practice evidence for Claims 1-2 (O(k) WOTS+), 4-5 (Base17, ContinuID), 8 (multi-isotope), 12-14 (ContinuID chain), 21 (multi-isotope dispatch).",
  "vectors": {
    "generate_secret": {
      "description": "Deterministic secret from a seed: SHAKE256(seed) squeezed to length/2 bytes (length=2048 hex chars -> 1024 bytes -> 2048 hex). All SDKs MUST produce this exact value. Cross-SDK parity lock (Batch AO, 2026-06-04).",
      "tests": [
        {
          "name": "test_seed_2048",
          "seed": "test-seed",
          "length": 2048,
          "expectedSecret": "",
          "invariants": {
            "length_hex_chars": 2048,
            "derivation": "shake256(seed) squeezed to 1024 bytes, hex-encoded"
          }
        }
      ]
    },
    "atom_value_format": {
      "description": "An atom V/B/F numeric value MUST serialize as an integer string (the validator parses it as i128); whole-number floats carry NO trailing '.0'. JS String(n) is canonical; all SDKs MUST match. Cross-SDK parity lock (Batch AQ, 2026-06-05).",
      "tests": [
        { "name": "whole_positive", "value": 1000, "expected": "1000" },
        { "name": "debit_negative", "value": -1000, "expected": "-1000" },
        { "name": "zero", "value": 0, "expected": "0" },
        { "name": "large_i64", "value": 9007199254740991, "expected": "9007199254740991" }
      ]
    },
    "continuid_chain": {
      "description": "ContinuID identity relay: two sequential wallet positions from same secret. Position2 is SHAKE256(position1, 256). Patent Claims 5, 12-14.",
      "tests": [
        {
