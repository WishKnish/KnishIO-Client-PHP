          "inputLength": 64,
          "expectedShake256": "9c8197c6eabbe59dbefaa8bd01ef798b02e017b480ca9425e7774b38bf889b8c",
          "expectedBase17OfHash": "03b080951cbc2f19ef19023a1gg1bg8gd6a8e0ebg68b700f52gagb28e6de25f8",
          "expectedKeyLength": 2048
        }
      ]
